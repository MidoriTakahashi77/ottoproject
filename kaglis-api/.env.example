# 環境変数設定例
# 本番用にコピーして使用: cp .env.example .env

# 環境設定
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ポート設定
PORT=8080

# Google Cloud設定（本番環境）
# GCP_PROJECT_ID=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceaccount.json

# Firestore設定（開発環境）
FIRESTORE_EMULATOR_HOST=firestore:8081
FIRESTORE_PROJECT_ID=furniture-detection-local

# モデル設定
MODEL_SIZE=n  # n, s, m, l, x
CONFIDENCE_THRESHOLD=0.5

# API設定
MAX_FILE_SIZE_MB=10
ALLOWED_ORIGINS=*
API_KEY=your-api-key-here  # 将来の認証用

# キャッシュ設定
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600