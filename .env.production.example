# 本番環境設定ファイルの例
# このファイルを .env.production にコピーして値を設定してください

# 環境設定
ENV=production
DEBUG=false
LOG_LEVEL=INFO

# GCP設定
GCP_PROJECT_ID=your-project-id
# サービスアカウントキー（Cloud Run環境では自動設定されるため不要）
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Firestore設定
# Cloud Run環境では自動的にプロジェクトのFirestoreに接続
# FIRESTORE_PROJECT_ID は GCP_PROJECT_ID と同じ値を使用

# モデル設定
MODEL_SIZE=n  # n(nano), s(small), m(medium) から選択
CONFIDENCE_THRESHOLD=0.5

# API設定
MAX_FILE_SIZE_MB=10
# CORS設定（カンマ区切りで複数指定可能）
ALLOWED_ORIGINS=*
# APIキー（セキュアなランダム文字列を生成してください）
API_KEY=your-secure-api-key-here-change-this

# キャッシュ設定
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600  # 1時間

# Cloud Run固有設定
PORT=8080  # Cloud Runはポート8080を期待