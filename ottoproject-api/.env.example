# Database (Local Development)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ottodb
DATABASE_USER=ottouser
DATABASE_PASSWORD=changeme

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_JWT_SECRET=your-jwt-secret-here-minimum-32-characters

# Google OAuth (via Supabase)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage Configuration
# ストレージプロバイダー: supabase, s3, minio
STORAGE_PROVIDER=supabase

# Supabase Storageバケット設定
# Supabase Dashboardで以下のバケットを作成：
# - images: アップロードされた画像
# - processed-results: 処理結果JSON
# - 3d-models: 3Dモデルファイル
# - temp-files: 一時ファイル（24時間で自動削除）

# API Settings
API_VERSION=v1
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=true

# ML Models
MODEL_CACHE_DIR=/tmp/models
DEVICE=cpu  # or cuda

# Environment
NODE_ENV=development
PYTHON_ENV=development